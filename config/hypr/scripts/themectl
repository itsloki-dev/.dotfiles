#!/usr/bin/env bash
set -e

#get the real path from where this script runs (resolves the symlink to original file)
SCRIPT_REAL="$(readlink -f "${BASH_SOURCE[0]}")"
# Walk up: scripts/ -> hypr/ -> config/ -> repo root    
DOTFILES_ROOT="$(realpath "$(dirname "$SCRIPT_REAL")/../../../")" #  .dotfiles/

THEMES_DIR="$DOTFILES_ROOT/themes"
WALLPAPER_DIR="$THEMES_DIR/wallpapers"
COLORS_DIR="$THEMES_DIR/colors"
COLORS_CSS="$THEMES_DIR/colors.css"
ACCENT_FILE="$THEMES_DIR/accent.color"
 
HYPR_DIR="$(realpath "$(dirname "$SCRIPT_REAL")/../")" #  .dotfiles/config/hypr
STATE_DIR="$HYPR_DIR/.state"

mkdir -p "$STATE_DIR" "$THEMES_DIR" "$WALLPAPER_DIR" "$COLORS_DIR"

# Lock to prevent race conditions (e.g. spamming keybind)
exec 9>"$STATE_DIR/.themectl.lock"
flock -n 9 || exit 0

CURRENT_FILE_WALLPAPER="$STATE_DIR/current_wallpaper"
CURRENT_FILE_COLOR="$STATE_DIR/current_color"

source "$(dirname "$SCRIPT_REAL")/lib.sh"
source "$(dirname "$SCRIPT_REAL")/functions.sh"

case "$1" in
    init)
        init_state
        ;;
    next-wallpaper)
        next_wallpaper
        ;;
    next-color)
        next_color
        ;;
    status)
        print_status
        ;;
    *)
        echo "Usage: themectl {init|next-wallpaper|next-color|status}"
        exit 1
        ;;
esac
